# Application
PORT=3000

# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_NAME=bond_sports_account

# Local dev only: auto-create schema from entities (no migrations yet).
# Keep false in non-dev environments.
DB_SYNCHRONIZE=true

# pgAdmin (local Docker Compose UI)
PGADMIN_PORT=5051
PGADMIN_DEFAULT_EMAIL=admin@bond-sports.com
PGADMIN_DEFAULT_PASSWORD=admin

# E2E tests use a dedicated database (never the dev DB above).
E2E_DB_NAME=bond_sports_account_e2e
